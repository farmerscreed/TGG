# ---------------------------------------------------------------------------
# TGG Campus Eco-Challenge — environment variables
# Copy to .env (local) and set the same values in your host (Vercel).
# NEXT_PUBLIC_* values are inlined at BUILD time — a redeploy is required after
# changing them in Vercel. See docs/CONFIGURATION.md for details.
# ---------------------------------------------------------------------------

# --- Supabase (required) ---------------------------------------------------
# Project API URL and the public "anon" key (safe to expose to the browser).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role key — SECRET. Bypasses RLS; used only by server-side admin
# routes (create-judge / create-coordinator / export). Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Site URLs -------------------------------------------------------------
# Public origin of the deployed site. Used for the signup email redirect.
NEXT_PUBLIC_SITE_URL=https://www.tggcampuschallenge.com

# Base URL used in outgoing email links. Falls back to https://tgg-eco.vercel.app.
NEXT_PUBLIC_APP_URL=https://www.tggcampuschallenge.com

# --- Email (Resend) --------------------------------------------------------
# SECRET. Required at build time (the Resend client initialises at module load).
RESEND_API_KEY=your-resend-api-key

# From address for outgoing mail. Falls back to "TGG Eco-Challenge <noreply@tgg-eco.org>".
RESEND_FROM_EMAIL=TGG Campus Eco-Challenge <noreply@tggcampuschallenge.com>
